<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="TaskPaneApp">
  <Id>i-write-addin-001</Id>
  <Version>1.0.0</Version>
  <ProviderName>i-Write</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="i-Write"/>
  <Description DefaultValue="AI 驱动的可信文档生成工作台"/>
  <IconUrl DefaultValue="https://localhost:3000/office-addin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/office-addin/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://github.com/docstudio/docstudio"/>
  <Hosts>
    <Host Name="Document"/>
    <Host Name="Workbook"/>
    <Host Name="Presentation"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="WordApi" MinVersion="1.1"/>
      <Set Name="ExcelApi" MinVersion="1.1"/>
      <Set Name="PowerPointApi" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/office-addin/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:nil="true"/>
</OfficeApp>
