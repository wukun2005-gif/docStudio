{
  "name": "i-write-excel-addin",
  "version": "1.0.0",
  "private": true,
  "description": "i-Write Excel Add-in — AI 驱动的可信文档生成",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "office-addin-debugging start manifest.xml --app excel",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.56.0",
    "@fluentui/react-icons": "^2.0.270",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "office-addin-debugging": "^5.0.0",
    "office-addin-test-server": "^1.0.0",
    "office-addin-manifest": "^1.0.0",
    "@types/office-js": "^1.0.500",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "@vitejs/plugin-react": "^4.3.4",
    "vitest": "^2.1.5",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3"
  }
}
